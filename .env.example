# Recommended: Google AI Studio (free with your Google account)
# Get your key in one click: https://aistudio.google.com/apikey
# Configure in the app via Settings → AI Provider
GOOGLE_AI_API_KEY=

# Optional: OpenAI API key (paid, advanced users only)
OPENAI_API_KEY=

# Optional: force absolute origin used in generated QR links.
# Use this when host headers are rewritten (reverse proxy / docker / tunnel).
# Example: QR_BASE_URL=http://192.168.1.22:3005
QR_BASE_URL=
